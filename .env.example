# AI_PROVIDER=openai, anthropic, or deepseek. DeepSeek uses the OpenAI-compatible Chat Completions API.
AI_PROVIDER=deepseek

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=
OPENAI_MODERATION_MODEL=omni-moderation-latest

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_BASE_URL=

VIBECHAT_DB_PATH=./backend/vibechat.db
NEXT_PUBLIC_API_URL=http://localhost:8058
